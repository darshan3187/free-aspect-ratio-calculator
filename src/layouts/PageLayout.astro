---
import '../styles/global.css';
import { inject } from '@vercel/analytics';

inject();

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  keywords?: string;
}

const {
  title,
  description,
  canonicalPath = "",
  keywords = "aspect ratio calculator, privacy policy, terms of service, about us, contact us"
} = Astro.props;

const siteUrl = "https://freeaspectratiocalculator.com";
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}/og-image.png`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="Aspect Ratio Calculator Studio" />
    <meta name="theme-color" content="#000000" />

    <!-- Security Headers & Privacy Directives -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' https://va.vercel-analytics.com; frame-ancestors 'self';" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Aspect Ratio Calculator" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="bg-[#000000] studio-grid-pattern text-neutral-300 min-h-screen flex flex-col font-sans antialiased selection:bg-white selection:text-black relative overflow-x-hidden">
    {/* Vercel DESIGN.md Hero Mesh Backdrop */}
    <div class="hero-mesh-bg"></div>

    <div class="relative z-10 flex-grow max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-4 sm:py-6">
      {/* Shared Header Navigation */}
      <header class="py-4 sm:py-6 border-b border-white/[0.08] mb-6 sm:mb-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3.5 group">
          <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl overflow-hidden border border-white/10 flex-shrink-0 bg-[#000000] group-hover:border-white/30 transition-colors shadow-lg">
            <img src="/logo.png" alt="Aspect Ratio Logo" class="w-full h-full object-cover" />
          </div>
          <div>
            <span class="text-lg sm:text-xl font-bold text-white tracking-display-lg block font-sans leading-none">
              Aspect Ratio Calculator.
            </span>
            <span class="text-[11px] text-[#888888] font-mono mt-1 block">100% Client-Side Private Utility</span>
          </div>
        </a>

        {/* Visible Navigation Links (MPA) */}
        <nav aria-label="Main Navigation" class="flex flex-wrap items-center gap-2">
          <a href="/" class="px-3.5 py-1.5 rounded-full text-xs font-mono font-medium text-neutral-300 hover:text-white bg-[#171717] hover:bg-neutral-800 border border-white/10 transition-all cursor-pointer">
            Calculator
          </a>
          <a href="/about-us" class="px-3.5 py-1.5 rounded-full text-xs font-mono font-medium text-neutral-300 hover:text-white bg-[#171717] hover:bg-neutral-800 border border-white/10 transition-all cursor-pointer">
            About Us
          </a>
          <a href="/privacy-policy" class="px-3.5 py-1.5 rounded-full text-xs font-mono font-medium text-neutral-300 hover:text-white bg-[#171717] hover:bg-neutral-800 border border-white/10 transition-all cursor-pointer">
            Privacy Policy
          </a>
          <a href="/terms-and-conditions" class="px-3.5 py-1.5 rounded-full text-xs font-mono font-medium text-neutral-300 hover:text-white bg-[#171717] hover:bg-neutral-800 border border-white/10 transition-all cursor-pointer">
            Terms of Service
          </a>
          <a href="/contact-us" class="px-3.5 py-1.5 rounded-full text-xs font-mono font-medium text-neutral-300 hover:text-white bg-[#171717] hover:bg-neutral-800 border border-white/10 transition-all cursor-pointer">
            Contact Us
          </a>
        </nav>
      </header>

      {/* Main Content Slot */}
      <main class="mb-12">
        <slot />
      </main>

      {/* Shared Footer Navigation */}
      <footer class="pt-8 pb-8 border-t border-white/[0.08] text-xs text-[#888888] space-y-4 font-sans">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p>© {new Date().getFullYear()} Aspect Ratio Calculator. All rights reserved.</p>
          <nav aria-label="Footer Navigation" class="flex flex-wrap items-center gap-4 font-mono text-[11px]">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <a href="/about-us" class="hover:text-white transition-colors">About Us</a>
            <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms-and-conditions" class="hover:text-white transition-colors">Terms of Service</a>
            <a href="/contact-us" class="hover:text-white transition-colors">Contact Us</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
