---
import RatioCraftApp from '../components/RatioCraftApp';
import '../styles/global.css';

const title = "Aspect Ratio Calculator — 16:9, 4:3, Pixels & Inches Online";
const description = "Free online aspect ratio calculator to calculate 16:9, 4:3, and 16x9 image & screen dimensions in pixels and inches. Features real-time visual canvas, social media presets, and 100% browser privacy.";
const siteUrl = "https://freeaspectratiocalculator.com";
const ogImageUrl = `${siteUrl}/og-image.png`;

// Multi-Schema Structured Data for Google Search Console & Rich Results
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Aspect Ratio Calculator",
  "url": siteUrl,
  "operatingSystem": "All (Web Browser)",
  "applicationCategory": "DesignApplication",
  "browserRequirements": "Requires HTML5 Canvas and JavaScript",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": description,
  "featureList": [
    "16:9 aspect ratio calculator and 16x9 dimension converter",
    "Image aspect ratio calculator with drag-and-drop file inspector",
    "Aspect ratio calculator pixels and inches high-res print math",
    "4:3 aspect ratio calculator and screen aspect ratio presets",
    "Interactive side-by-side aspect ratio comparison tool",
    "100% Client-side zero server upload privacy architecture"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an aspect ratio and how to calculate aspect ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>An aspect ratio is the proportional relationship between an image or display screen's width and height, expressed as two numbers separated by a colon (such as 16:9 or 4:3). To calculate aspect ratio scaled dimensions: Multiply original height by target width, then divide by original width. Formula: Target Height = (Original Height × Target Width) ÷ Original Width.</p>"
      }
    },
    {
      "@type": "Question",
      "name": "What is a 16:9 aspect ratio calculator or 16x9 aspect ratio calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>A 16:9 aspect ratio calculator (also called a 16x9 aspect ratio calculator) determines dimensions for high-definition video (1920x1080), 4K Ultra HD (3840x2160), YouTube thumbnails, and widescreen desktop monitors.</p>"
      }
    },
    {
      "@type": "Question",
      "name": "How does an aspect ratio calculator pixels and aspect ratio calculator inches converter work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>An aspect ratio calculator in pixels calculates exact pixel counts for digital UI design and web containers. The aspect ratio calculator inches feature divides pixel dimensions by target DPI (such as 300 DPI for high-resolution print) to provide physical print measurements in inches and centimeters.</p>"
      }
    },
    {
      "@type": "Question",
      "name": "What is a 4:3 aspect ratio calculator used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>A 4:3 aspect ratio calculator is used for legacy television broadcasts, retro photo framing, iPad display resolutions (2048x1536), and micro four-thirds camera sensors.</p>"
      }
    },
    {
      "@type": "Question",
      "name": "How to use a screen aspect ratio calculator for monitors and mobile devices?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>Use a screen aspect ratio calculator to compute display proportions for ultrawide gaming monitors (21:9 and 32:9), mobile vertical video screens (9:16 for Reels/TikTok), and custom display resolutions online.</p>"
      }
    }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Aspect Ratio for Images and Screens",
  "description": "Step-by-step guide to calculating target image dimensions and aspect ratios online.",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Enter Source Width & Height",
      "text": "Enter your original width and height (e.g., 1920 x 1080 for 16:9) or drop an image file to auto-detect."
    },
    {
      "@type": "HowToStep",
      "name": "Enter Target Width or Select Preset",
      "text": "Type your desired output width or click a preset (e.g., 16:9, 4:3, or Instagram 4:5)."
    },
    {
      "@type": "HowToStep",
      "name": "View Pixels, Inches & Code",
      "text": "Get calculated height in pixels and 300 DPI print inches, inspect visual crop framing, and copy CSS code."
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Aspect Ratio Calculator",
      "item": siteUrl
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="aspect ratio calculator, 16:9 aspect ratio calculator, image aspect ratio calculator, 16x9 aspect ratio calculator, aspect ratio calculator inches, aspect ratio calculator pixels, calculate aspect ratio, how to calculate aspect ratio, aspect ratio calculator online, 4:3 aspect ratio calculator, screen aspect ratio calculator, resize image aspect ratio, online aspect calculator" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="Aspect Ratio Calculator Studio" />
    <meta name="theme-color" content="#000000" />

    <!-- Security Headers & Privacy Directives -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'self';" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=(), payment=(), usb=(), display-capture=()" />

    <!-- Google Search Console Verification Meta Tag -->
    <meta name="google-site-verification" content="YOUR_GOOGLE_SEARCH_CONSOLE_VERIFICATION_CODE" />

    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / Facebook Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Aspect Ratio Calculator" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data (JSON-LD) for Google Search Console & SERP Rich Snippets -->
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body class="bg-[#000000] text-[#a1a1a1] antialiased selection:bg-white selection:text-black">
    <RatioCraftApp client:load />
  </body>
</html>
