---
import PageLayout from '../layouts/PageLayout.astro';

const title = "Terms & Conditions — Aspect Ratio Calculator";
const description = "Terms of service and commercial license terms for using the Free Aspect Ratio Calculator web application.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freeaspectratiocalculator.com" },
    { "@type": "ListItem", "position": 2, "name": "Terms & Conditions", "item": "https://freeaspectratiocalculator.com/terms-and-conditions" }
  ]
};
---

<PageLayout title={title} description={description} canonicalPath="/terms-and-conditions">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="studio-card p-6 sm:p-10 space-y-6">
    <div class="border-b border-white/[0.08] pb-5">
      <span class="text-xs font-mono text-[#888888] uppercase tracking-wider block mb-1">Legal Agreement</span>
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-display-lg font-sans">
        Terms & Conditions.
      </h1>
      <p class="text-xs font-mono text-[#888888] mt-1">
        Last Updated: January 1, 2026
      </p>
    </div>

    <div class="space-y-4 text-sm leading-relaxed text-neutral-300 font-sans">
      <h2 class="text-base font-bold text-white font-sans">1. Acceptance of Terms</h2>
      <p>
        By accessing or using <strong>Aspect Ratio Calculator</strong>, you agree to be bound by these Terms and Conditions. If you do not agree with any part of these terms, you may not access or use the application.
      </p>

      <h2 class="text-base font-bold text-white font-sans">2. Permitted Commercial & Personal Use</h2>
      <p>
        Our web application is provided 100% free of charge for both personal and commercial use. Designers, developers, agencies, and video editors are permitted to use calculations, scale tables, and exported code snippets in commercial software, web design projects, or media production without royalty fees.
      </p>

      <h2 class="text-base font-bold text-white font-sans">3. Open-Source Code Snippets (MIT License)</h2>
      <p>
        All developer code snippets generated by our application (including modern CSS <code class="font-mono text-white bg-[#171717] px-1.5 py-0.5 rounded">aspect-ratio</code> properties, Tailwind CSS utility classes, and SVG <code class="font-mono text-white bg-[#171717] px-1.5 py-0.5 rounded">viewBox</code> attributes) are licensed under the open-source MIT License.
      </p>

      <h2 class="text-base font-bold text-white font-sans">4. Intellectual Property</h2>
      <p>
        All branding, interface designs, logos, software logic, and custom components of the Aspect Ratio Calculator platform remain the intellectual property of the studio.
      </p>

      <h2 class="text-base font-bold text-white font-sans">5. Disclaimer of Warranties</h2>
      <p>
        The tool is provided "as is" and "as available" without warranties of any kind. While mathematical calculations use precise Greatest Common Divisor (GCD) algorithms, users are responsible for verifying final physical resolution specifications prior to high-volume commercial print production.
      </p>
    </div>
  </article>
</PageLayout>
