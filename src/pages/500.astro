---
import PageLayout from '../layouts/PageLayout.astro';

const title = "500: Server Error — Aspect Ratio Calculator";
const description = "An internal server error occurred. Return to the Free Aspect Ratio Calculator home page.";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freeaspectratiocalculator.com" },
    { "@type": "ListItem", "position": 2, "name": "500 Internal Server Error", "item": "https://freeaspectratiocalculator.com/500" }
  ]
};
---

<PageLayout title={title} description={description} canonicalPath="/500">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="studio-card p-8 sm:p-12 text-center space-y-6 max-w-xl mx-auto my-8 sm:my-12">
    {/* Vercel 500 Status Pill */}
    <div>
      <span class="inline-flex items-center gap-2 px-3.5 py-1 rounded-full text-xs font-mono font-bold text-white bg-[#171717] border border-white/20 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        <span>500 SERVER ERROR</span>
      </span>
    </div>

    <div class="space-y-3">
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-display-lg font-sans leading-tight">
        500: Internal Server Error.
      </h1>
      <p class="text-xs sm:text-sm text-[#888888] font-sans max-w-md mx-auto leading-relaxed">
        An unexpected error occurred while processing this request. Rest assured, your browser process memory remains secure.
      </p>
    </div>

    {/* Actions */}
    <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-white text-black hover:bg-neutral-200 font-semibold text-xs font-sans transition-all active:scale-95 cursor-pointer shadow-md"
      >
        Reload Calculator
      </a>
      <a
        href="/contact-us"
        class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-[#171717] text-white hover:bg-neutral-800 border border-white/10 font-semibold text-xs font-sans transition-all active:scale-95 cursor-pointer"
      >
        Report Issue
      </a>
    </div>

    {/* System Note */}
    <div class="pt-6 border-t border-white/[0.08]">
      <p class="text-[11px] font-mono text-[#888888]">
        100% Client-Side Math Engine Status: Operational
      </p>
    </div>
  </div>
</PageLayout>
